TMDB_API_KEY=coloque_a_sua_chave_tmdb_aqui
TMDB_READ_ACCESS_TOKEN=coloque_o_read_access_token_tmdb_aqui

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=filme
DB_USER=root
DB_PASS=

# URL do frontend Angular (prioritário nos links dos emails). Se vazio, usa o cabeçalho HTTP Origin do pedido.
FRONTEND_BASE_URL=http://localhost:4200

# 1/true = gravar em backend/storage/mail.log (recomendado em XAMPP). 0/false = tentar PHP mail().
MAIL_LOG_ONLY=1
MAIL_FROM=noreply@localhost
